[init]
  defaultBranch = main
[user]
  signingkey = /home/sean/.ssh/id_ed25519.pub
	email = sean@seankleinjung.com
	name = Sean Kleinjung
[push]
  autoSetupRemote = true
[gpg]
  format = ssh
[commit]
  gpgsign = true
[tag]
  gpgsign = true

# twin digital — selected by remote org, not folder name, so any clone or worktree
# of a github.com/twin-digital repo gets this identity regardless of where it lives.
# (One line per URL form: HTTPS, SCP-style SSH, ssh:// — git matches the literal string.)
[includeIf "hasconfig:remote.*.url:https://github.com/twin-digital/**"]
  path = ./.gitconfig.d/twin-digital.inc
[includeIf "hasconfig:remote.*.url:git@github.com:twin-digital/**"]
  path = ./.gitconfig.d/twin-digital.inc
[includeIf "hasconfig:remote.*.url:ssh://git@github.com/twin-digital/**"]
  path = ./.gitconfig.d/twin-digital.inc

# thrashplay
[includeIf "hasconfig:remote.*.url:https://github.com/thrashplay/**"]
  path = ./.gitconfig.d/thrashplay.inc
[includeIf "hasconfig:remote.*.url:git@github.com:thrashplay/**"]
  path = ./.gitconfig.d/thrashplay.inc
[includeIf "hasconfig:remote.*.url:ssh://git@github.com/thrashplay/**"]
  path = ./.gitconfig.d/thrashplay.inc

# pegasuspad
[includeIf "hasconfig:remote.*.url:https://github.com/pegasuspad/**"]
  path = ./.gitconfig.d/pegasuspad.inc
[includeIf "hasconfig:remote.*.url:git@github.com:pegasuspad/**"]
  path = ./.gitconfig.d/pegasuspad.inc
[includeIf "hasconfig:remote.*.url:ssh://git@github.com/pegasuspad/**"]
  path = ./.gitconfig.d/pegasuspad.inc
[rebase]
	gpgsign = true
